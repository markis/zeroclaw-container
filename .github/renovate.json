{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "schedule": ["before 6am on Monday"],
  "prConcurrentLimit": 10,
  "labels": ["dependencies"],
  "branchPrefix": "renovate/",
  "additionalBranchPrefix": "{{depName}}-",
  "customManagers": [
    {
      "description": "kubectl apt repo (minor version tracks kubernetes releases)",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "pkgs\\.k8s\\.io/core:/stable:/v(?<currentValue>\\d+\\.\\d+)/deb"
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "extractVersionTemplate": "^v(?<version>\\d+\\.\\d+)\\."
    },
    {
      "description": "Python version for uv install",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "uv python install --preview --default (?<currentValue>\\d+\\.\\d+)"
      ],
      "depNameTemplate": "python/cpython",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "extractVersionTemplate": "^v(?<version>\\d+\\.\\d+)\\."
    },
    {
      "description": "helm",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["HELM_VERSION=(?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "helm/helm",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "yq",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["YQ_VERSION=(?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "mikefarah/yq",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "restic",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["RESTIC_VERSION=(?<currentValue>[0-9.]+)"],
      "depNameTemplate": "restic/restic",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "neovim (checksums must be updated manually or via CI)",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "neovim/neovim/releases/download/v(?<currentValue>[0-9.]+)/"
      ],
      "depNameTemplate": "neovim/neovim",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "agent-browser (checksums must be updated manually or via CI)",
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["AGENT_BROWSER_VERSION=(?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "vercel-labs/agent-browser",
      "datasourceTemplate": "github-releases"
    }
  ]
}